#!/usr/bin/env bash

function export_aws_env() {
	if export_output=$(aws configure export-credentials --profile "$1" --format env 2>/dev/null); then
		eval "$export_output"
		echo "AWS environment variables exported"
	else
		echo "Failed to export AWS environment variables" >&2
		return 1
	fi
}

FORCE=false
PROFILE=""
for arg in "$@"; do
	case "$arg" in
		-f|--force) FORCE=true ;;
		*) PROFILE="$arg" ;;
	esac
done

if [[ -z "$PROFILE" ]]; then
	echo "Usage: awslogin [-f|--force] <profile>" >&2
	return 1
fi

# Case 1: Already authenticated (skip if --force)
if [[ "$FORCE" != true ]] && aws sts get-caller-identity --profile "$PROFILE" >/dev/null 2>&1; then
	echo "Already authenticated with profile: $PROFILE"
	export_aws_env "$PROFILE"
	return $?
fi

if [[ "$FORCE" == true ]]; then
	rm -f ~/.aws/sso/cache/*.json 2>/dev/null
fi

echo "Logging in with profile: $PROFILE"

# Remember the frontmost app so we can switch back later
CURRENT_APP=$(osascript -e 'return short name of (info for (path to frontmost application))')

aws sso login --profile "$PROFILE" &
SSO_PID=$!

# Give the browser a moment to open and start redirecting
sleep 2

# Poll: try to auto-click "Allow access" in Arc while waiting for the CLI to finish.
# The new AWS SSO flow (OAuth2 PKCE) redirects through Microsoft Entra ID for auth,
# then lands on the AWS SSO consent page. Once approved, the browser redirects to a
# localhost callback and the CLI completes automatically.
while kill -0 "$SSO_PID" 2>/dev/null; do
	osascript <<'APPLESCRIPT' 2>/dev/null
tell application "Arc"
    if (count of windows) > 0 then
        tell front window's active tab
            execute javascript "
                (function() {
                    var btns = document.querySelectorAll('button');
                    for (var i = 0; i < btns.length; i++) {
                        if (btns[i].textContent.trim() === 'Allow access' && !btns[i].disabled) {
                            btns[i].click();
                            return;
                        }
                    }
                })();
            "
        end tell
    end if
end tell
APPLESCRIPT
	sleep 1
done

wait "$SSO_PID"
SSO_EXIT=$?

# Give the browser a moment to settle on the callback page
sleep 0.5

# Close the SSO/callback tab in Arc (matches any URL from the auth redirect chain)
osascript <<'APPLESCRIPT' 2>/dev/null
tell application "Arc"
    if (count of windows) > 0 then
        tell front window
            set tabURL to URL of active tab
            if tabURL contains "127.0.0.1" or tabURL contains "awsapps.com" or tabURL contains "amazonaws.com" or tabURL contains "microsoftonline.com" then
                close active tab
            end if
        end tell
    end if
end tell
APPLESCRIPT

# Restore your previous frontmost app
osascript -e "tell application \"$CURRENT_APP\" to activate"

# Verify login
if [[ $SSO_EXIT -ne 0 ]] || ! aws sts get-caller-identity --profile "$PROFILE" >/dev/null 2>&1; then
	echo "SSO login failed" >&2
	return 1
fi

export_aws_env "$PROFILE"
